{
    "name": "@mysten-incubation/memwal",
    "version": "0.0.7",
    "description": "Walrus Memory — Privacy-first AI memory SDK with Ed25519 delegate key auth",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./account": {
            "import": "./dist/account-entry.js",
            "types": "./dist/account-entry.d.ts"
        },
        "./manual": {
            "import": "./dist/manual-entry.js",
            "types": "./dist/manual-entry.d.ts"
        },
        "./ai": {
            "import": "./dist/ai/index.js",
            "types": "./dist/ai/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@noble/ed25519": "^2.3.0",
        "@noble/hashes": "^2.0.0"
    },
    "devDependencies": {
        "@ai-sdk/provider": "^2.0.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.5.0"
    },
    "peerDependencies": {
        "ai": ">=4.0.0",
        "zod": "^3.23.0",
        "@mysten/sui": ">=2.5.0",
        "@mysten/seal": ">=1.1.0",
        "@mysten/walrus": ">=1.0.3"
    },
    "peerDependenciesMeta": {
        "ai": {
            "optional": true
        },
        "zod": {
            "optional": true
        },
        "@mysten/walrus": {
            "optional": true
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "keywords": [
        "ai",
        "memory",
        "privacy",
        "walrus-memory",
        "walrus",
        "sui",
        "encryption",
        "ed25519",
        "tee"
    ],
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MystenLabs/MemWal.git",
        "directory": "packages/sdk"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
